   ],
   "execution_count": 36
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Khảo sát Ánh sáng (CLAHE)"
   ],
   "id": "9766291f7ac55787"
  },
  {
   "cell_type": "code",
   "metadata": {
    "ExecuteTime": {
     "end_time": "2026-07-15T16:01:59.778261100Z",
     "start_time": "2026-07-15T16:01:59.384242400Z"
    }
   },
   "source": [
    "# Tách kênh L bình thường (Chưa qua CLAHE)\n",
    "lab_image = cv2.cvtColor(clean_img, cv2.COLOR_BGR2LAB)\n",
    "l_normal, _, _ = cv2.split(lab_image)\n",
    "\n",
    "# Chạy CLAHE\n",
    "clahe_color_img, l_clahe = enhance_contrast_clahe(clean_img, clip_limit=1.1)\n",
    "\n",
    "fig, axs = plt.subplots(1, 2, figsize=(12, 5))\n",
    "axs[0].imshow(l_normal, cmap='gray')\n",
    "axs[0].set_title(\"Kenh L Binh Thuong (Vien u bi chim)\")\n",
    "axs[0].axis('off')\n",
    "\n",
    "axs[1].imshow(l_clahe, cmap='gray')\n",
    "axs[1].set_title(\"Kenh L da qua CLAHE (Vien u noi bat)\")\n",
    "axs[1].axis('off')\n",
    "plt.show()"
   ],
   "id": "70d2ad156c3e7923",
   "outputs": [
    {
     "data": {
      "text/plain": [
       "<Figure size 1200x500 with 2 Axes>"
      ],
