     }
    }
   ],
   "execution_count": 35
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Khảo sát DullRazor (Xóa lông)"
   ],
   "id": "683329ea2bc24ecc"
  },
  {
   "cell_type": "code",
   "metadata": {
    "ExecuteTime": {
     "end_time": "2026-07-15T16:01:59.361219700Z",
     "start_time": "2026-07-15T16:01:58.804500100Z"
    }
   },
   "source": [
    "# Chạy DullRazor (Trong source trả về ảnh sạch và mask lông)\n",
    "clean_img, hair_mask = remove_hair(img_no_corners, kernel_size=15, inpaint_rad=3)\n",
    "\n",
    "# Tự chạy lại Blackhat để trực quan hóa rõ sợi lông (Do hàm gốc không return blackhat)\n",
    "gray = cv2.cvtColor(img_no_corners, cv2.COLOR_BGR2GRAY)\n",
    "kernel = cv2.getStructuringElement(cv2.MORPH_ELLIPSE, (15, 15))\n",
    "blackhat = cv2.morphologyEx(gray, cv2.MORPH_BLACKHAT, kernel)\n",
    "\n",
    "fig, axs = plt.subplots(1, 3, figsize=(18, 5))\n",
    "axs[0].imshow(cv2.cvtColor(img_no_corners, cv2.COLOR_BGR2RGB))\n",
    "axs[0].set_title(\"1. Truoc khi cao long\")\n",
    "axs[0].axis('off')\n",
    "\n",
    "axs[1].imshow(blackhat, cmap='gray')\n",
    "axs[1].set_title(\"2. Anh Blackhat (Chi hien soi long)\")\n",
    "axs[1].axis('off')\n",
    "\n",
    "axs[2].imshow(cv2.cvtColor(clean_img, cv2.COLOR_BGR2RGB))\n",
    "axs[2].set_title(\"3. Anh da noi suy (Inpainting)\")\n",
    "axs[2].axis('off')\n",
    "plt.show()"
   ],
   "id": "676f5ac66169dba0",
   "outputs": [
    {
     "data": {
      "text/plain": [
       "<Figure size 1800x500 with 3 Axes>"
      ],
      "image/png": ""
     },
