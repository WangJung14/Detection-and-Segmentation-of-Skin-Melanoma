   "source": [
    "## 4. Khảo sát Khử nhiễu (Gaussian Blur)"
   ],
   "id": "e83cec17d7c5961"
  },
  {
   "cell_type": "code",
   "metadata": {
    "ExecuteTime": {
     "end_time": "2026-07-15T16:02:00.129511500Z",
     "start_time": "2026-07-15T16:01:59.780261100Z"
    }
   },
   "source": [
    "from src.preprocessing import boost_faint_edges\n",
    "\n",
    "# Boost nhẹ viền mờ trước khi làm mượt (theo luồng pipeline gốc)\n",
    "boosted_l, _ = boost_faint_edges(l_clahe)\n",
    "\n",
    "# Khử nhiễu bằng Gaussian Blur\n",
    "smooth_l = cv2.GaussianBlur(boosted_l, (5, 5), 0)\n",
    "\n",
    "fig, axs = plt.subplots(1, 2, figsize=(12, 5))\n",
    "axs[0].imshow(boosted_l, cmap='gray')\n",
    "axs[0].set_title(\"Truoc Gaussian Blur (Con ro lo chan long)\")\n",
    "axs[0].axis('off')\n",
    "\n",
    "axs[1].imshow(smooth_l, cmap='gray')\n",
    "axs[1].set_title(\"Sau Gaussian Blur (Be mat min mang)\")\n",
    "axs[1].axis('off')\n",
    "plt.show()"
   ],
   "id": "4e0412585ac5d558",
