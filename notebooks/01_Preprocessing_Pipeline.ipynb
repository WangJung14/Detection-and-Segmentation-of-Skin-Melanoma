    "# 01_Preprocessing_Pipeline.ipynb - tiền xử lý ảnh\n",
    "**Mục tiêu:** Trình diễn từng bước biến đổi trạng thái ảnh từ lúc đầy nhiễu đến khi \"sạch sẽ\"."
   ],
   "id": "83104af19d220742"
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Nạp ảnh gốc & Áp dụng Circular Mask (Cắt góc đen)"
   ],
   "id": "344761743c717774"
  },
  {
   "cell_type": "code",
   "metadata": {
    "ExecuteTime": {
     "end_time": "2026-07-15T16:01:58.799674100Z",
     "start_time": "2026-07-15T16:01:58.544726900Z"
    }
   },
   "source": [
    "import cv2\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import sys\n",
    "import os\n",
    "\n",
    "# Đảm bảo Kernel nhận diện được thư mục src\n",
    "sys.path.append(r'd:\\Computer Vision Final Project\\Src code')\n",
    "\n",
    "from src.preprocessing import apply_circular_mask, remove_hair, enhance_contrast_clahe\n",
    "\n",
    "# Đặt đường dẫn tuyệt đối cho an toàn\n",
    "img_path = r'd:\\Computer Vision Final Project\\Src code\\data\\toy_data\\melanoma\\ISIC_0000161.jpg'\n",
    "img = cv2.imread(img_path)\n",
    "img = cv2.resize(img, (600, 450))\n",
    "\n",
    "# Áp dụng Circular Mask để xóa viền đen ống kính\n",
    "img_no_corners = apply_circular_mask(img, radius_reduction=1.2)\n",
    "\n",
    "fig, axs = plt.subplots(1, 2, figsize=(12, 5))\n",
    "axs[0].imshow(cv2.cvtColor(img, cv2.COLOR_BGR2RGB))\n",
    "axs[0].set_title(\"Anh Goc (Bi den 4 goc)\")\n",
    "axs[0].axis('off')\n",
    "\n",
    "axs[1].imshow(cv2.cvtColor(img_no_corners, cv2.COLOR_BGR2RGB))\n",
    "axs[1].set_title(\"Da ap dung Circular Mask\")\n",
    "axs[1].axis('off')\n",
    "plt.show()"
   ],
   "id": "cffa08b878ec361f",
   "outputs": [
    {
     "data": {
      "text/plain": [
       "<Figure size 1200x500 with 2 Axes>"
      ],
