     "start_time": "2026-07-15T18:43:48.943706300Z"
    }
   },
   "source": [
    "import cv2\n",
    "import matplotlib.pyplot as plt\n",
    "import sys\n",
    "import os\n",
    "\n",
    "# Đảm bảo import được từ src\n",
    "sys.path.append(r'd:\\Computer Vision Final Project\\Src code')\n",
    "\n",
    "from src.parameter_sweep import sweep_dullrazor, sweep_clahe, sweep_otsu, sweep_kmeans, sweep_snakes, sweep_abcd_compactness\n",
    "\n",
    "img_path = r'd:\\Computer Vision Final Project\\Src code\\data\\train\\images\\ISIC_0000074.jpg'\n",
    "gt_path = r'd:\\Computer Vision Final Project\\Src code\\data\\train\\masks\\ISIC_0000074_segmentation.png'\n",
    "\n",
    "img = cv2.imread(img_path)\n",
    "img = cv2.resize(img, (600, 450))\n",
    "gt_mask = cv2.resize(cv2.imread(gt_path, 0), (600, 450))\n",
    "\n",
    "print(\"Đã nạp xong ảnh để chuẩn bị khảo sát!\")"
   ],
   "id": "f6695866287620db",
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Đã nạp xong ảnh để chuẩn bị khảo sát!\n"
     ]
    }
   ],
   "execution_count": 1
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Khảo sát Kích thước Chổi Xóa lông (DullRazor)\n",
    "- **kernel = 5:** Chổi quá nhỏ, chỉ xóa được lông tơ, để lọt lông to đen rậm.\n",
    "- **kernel = 15:** Vừa vặn, làm sạch lông mà vẫn giữ được ranh giới khối u.\n",
    "- **kernel = 25:** Quá to, gây nhòe nhoẹt (Blur) mạnh lên các vân da và làm nhòe viền u."
   ],
   "id": "7a8c3ae8b6ae6199"
  },
  {
   "cell_type": "code",
   "metadata": {
    "ExecuteTime": {
     "end_time": "2026-07-15T18:43:49.620678700Z",
     "start_time": "2026-07-15T18:43:49.115008600Z"
    }
   },
   "source": [
    "fig = sweep_dullrazor(img)\n",
    "plt.show()"
   ],
