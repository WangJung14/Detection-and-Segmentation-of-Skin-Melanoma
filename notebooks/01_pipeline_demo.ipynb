 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Toàn cảnh Pipeline Xử lý ảnh Y khoa (End-to-End Demo)\n",
    "**Mục tiêu:** Trình diễn trực quan toàn bộ vòng đời của bức ảnh: Từ lúc đầy nhiễu sáng/lông $\\rightarrow$ Làm sạch $\\rightarrow$ Bóc tách bằng Spatial K-Means + Snakes $\\rightarrow$ Chấm điểm ABCD."
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Import Thư viện & Load Ảnh"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import cv2\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import sys\n",
    "import os\n",
    "\n",
    "# Đảm bảo import được từ src\n",
    "sys.path.append(r'd:\\Computer Vision Final Project\\Src code')\n",
    "\n",
    "from src.preprocessing import apply_circular_mask, remove_hair, enhance_contrast_clahe, boost_faint_edges\n",
    "from src.segmentation import get_kmeans_mask, get_snakes_mask\n",
    "from src.features import evaluate_abcd_rule\n",
    "from src.evaluation import calculate_iou\n",
    "\n",
    "def show_images(imgs, titles):\n",
    "    fig, axs = plt.subplots(1, len(imgs), figsize=(6 * len(imgs), 5))\n",
    "    if len(imgs) == 1: axs = [axs]\n",
    "    for ax, img, title in zip(axs, imgs, titles):\n",
    "        if len(img.shape) == 3: ax.imshow(cv2.cvtColor(img, cv2.COLOR_BGR2RGB))\n",
    "        else: ax.imshow(img, cmap='gray')\n",
    "        ax.set_title(title)\n",
    "        ax.axis('off')\n",
    "    plt.show()\n",
    "\n",
    "img = cv2.imread(r'd:\\Computer Vision Final Project\\Src code\\data\\train\\images\\ISIC_0000074.jpg')\n",
    "img = cv2.resize(img, (600, 450))\n",
    "gt = cv2.imread(r'd:\\Computer Vision Final Project\\Src code\\data\\train\\masks\\ISIC_0000074_segmentation.png', 0)\n",
    "gt = cv2.resize(gt, (600, 450))\n",
    "show_images([img, gt], ['Anh goc', 'Ground Truth (Bac si)'])\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Tiền xử lý: DullRazor (Xóa lông) & CLAHE (Cân bằng sáng)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "img_no_corners = apply_circular_mask(img, 0.85)\n",
    "clean_img, hair_mask = remove_hair(img_no_corners, kernel_size=15, inpaint_rad=3)\n",
    "clahe_color, clahe_gray = enhance_contrast_clahe(clean_img, 1.1)\n",
    "smooth_l = cv2.GaussianBlur(boost_faint_edges(clahe_gray)[0], (5, 5), 0)\n",
    "smooth_l = apply_circular_mask(smooth_l, 0.85)\n",
    "clahe_color = apply_circular_mask(clahe_color, 0.85)\n",
    "\n",
    "show_images([hair_mask, clean_img, clahe_color], ['Mat na Long (DullRazor)', 'Anh cao long', 'Tuong phan CLAHE'])\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Phân đoạn K-Means (Bắt viền nhạt bằng Spatial Prior)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print(\"Sử dụng K-Means lấy 2 cụm màu gần tâm ảnh nhất để không bỏ sót vùng viền nhạt...\")\n",
    "kmeans_mask = get_kmeans_mask(clahe_color, k=4)\n",
    "res_kmeans = img.copy()\n",
    "contours, _ = cv2.findContours(kmeans_mask, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)\n",
    "cv2.drawContours(res_kmeans, contours, -1, (0, 255, 0), 2)\n",
    "\n",
    "show_images([kmeans_mask, res_kmeans], ['Mask K-Means', 'Vien K-Means de len anh'])\n",
    "print(f\"IoU K-Means: {calculate_iou(kmeans_mask, gt)*100:.2f}%\")\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Rắn bò Morphological Snakes (Chan-Vese)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print(\"Dây thun Snakes bò 35 vòng từ mốc K-Means để ôm khít rãnh khối u...\")\n",
    "snakes_mask = get_snakes_mask(smooth_l, kmeans_mask, num_iter=35)\n",
    "res_snakes = img.copy()\n",
    "contours, _ = cv2.findContours(snakes_mask, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)\n",
    "cv2.drawContours(res_snakes, contours, -1, (0, 255, 255), 2)\n",
    "\n",
    "show_images([res_kmeans, res_snakes], ['Truoc Snakes (K-Means)', 'Sau Snakes (K-Means + Snakes)'])\n",
    "print(f\"IoU Snakes: {calculate_iou(snakes_mask, gt)*100:.2f}%\")\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Đánh giá Y khoa (ABCD Rule)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "result = evaluate_abcd_rule(img, snakes_mask, snakes_mask)\n",
    "print(\"=\"*50)\n",
    "print(\"ĐÁNH GIÁ ĐẶC TRƯNG ABCD LÂM SÀNG:\")\n",
    "print(f\" - [A] Asymmetry (Bất đối xứng) : {result['A']} điểm\")\n",
    "print(f\" - [B] Border (Nham nhở)        : {result['B']} điểm\")\n",
    "print(f\" - [C] Color (Đa sắc)           : {result['C']} điểm\")\n",
    "print(f\" - [D] Diameter (Đường kính)    : {result['D_score']} điểm ({result['D_mm']} mm)\")\n",
    "print(\"-\"*50)\n",
    "print(f\"=> TOTAL DERMOSCOPY SCORE (TDS): {result['TDS']}\")\n",
    "print(f\"=> CHẨN ĐOÁN (DIAGNOSIS)       : {result['Diagnosis'].upper()}\")\n",
    "print(\"=\"*50)\n"
   ]
  }
 ],
